module NatPlusCommutative where

-- Подключаем стандартные определения натуральных чисел
open import Data.Nat using (ℕ; zero; suc; _+_)

-- Подключаем работу с равенствами
open import Relation.Binary.PropositionalEquality
  using (_≡_; refl; cong; sym; trans)

------------------------------------------------------------------------
-- 📌 Идея:
--
-- Мы хотим доказать:
--     m + n ≡ n + m
--
-- Это и есть переместительный закон (коммутативность сложения).
--
-- В Agda это не "теорема", а функция (доказательство),
-- которая возвращает значение типа равенства.
------------------------------------------------------------------------

------------------------------------------------------------------------
-- 🔧 Вспомогательная лемма:
--
-- m + suc n ≡ suc (m + n)
--
-- Она нужна, потому что сложение в стандартной библиотеке
-- определено по первому аргументу:
--
--   zero + n = n
--   suc m + n = suc (m + n)
--
-- Но нам иногда нужно "протолкнуть" suc вправо.
------------------------------------------------------------------------

+-suc : (m n : ℕ) → m + suc n ≡ suc (m + n)

-- База индукции, используется индукция по m:
-- 0 + suc n = suc n
-- правая часть: suc (0 + n) = suc n
-- значит равны по определению → refl
-- refl — доказательство равенства по определению
+-suc zero n = refl

-- Шаг индукции:
-- cong suc — если a ≡ b, то suc a ≡ suc b
-- (suc m) + suc n = suc (m + suc n)
-- По индукционному предположению:
-- m + suc n ≡ suc (m + n)
--
-- Тогда:
-- suc (m + suc n) ≡ suc (suc (m + n))
-- 
-- Используем cong (поднятие равенства через suc)
+-suc (suc m) n = cong suc (+-suc m n)

------------------------------------------------------------------------
-- 🔧 Лемма: правый нейтральный элемент
--
-- m + 0 ≡ m
------------------------------------------------------------------------

+-identityʳ : (m : ℕ) → m + zero ≡ m

+-identityʳ zero = refl

-- (suc m) + 0 = suc (m + 0)
-- по ИП: m + 0 ≡ m
-- значит: suc (m + 0) ≡ suc m
+-identityʳ (suc m) = cong suc (+-identityʳ m)

------------------------------------------------------------------------
-- 📌 Основная теорема: коммутативность сложения
--
-- m + n ≡ n + m
------------------------------------------------------------------------

+-comm : (m n : ℕ) → m + n ≡ n + m

-- База:
-- 0 + n = n
-- n + 0 ≡ n  (по лемме)
-- значит:
-- n ≡ n + 0
-- нужно перевернуть равенство → sym
+-comm zero n = sym (+-identityʳ n)

-- Шаг:
-- (suc m) + n = suc (m + n)
--
-- Хотим получить:
-- n + (suc m)
--
-- План:
-- 1. По ИП: m + n ≡ n + m
-- 2. Поднимаем через suc:
--    suc (m + n) ≡ suc (n + m)
-- 3. Преобразуем:
--    n + suc m ≡ suc (n + m)   (через +-suc)
--
-- Соединяем через trans
+-comm (suc m) n =
  trans
    (cong suc (+-comm m n))   -- шаг 1+2
    (sym (+-suc n m))         -- шаг 3 (в обратную сторону)